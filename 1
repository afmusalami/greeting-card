<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sadara Greeting Card</title>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #2f7cff;
      --white: #ffffff;
      --text: #f4f7fb;
      --muted: rgba(255,255,255,0.7);
      --glass: rgba(255,255,255,0.12);
      --glass-strong: rgba(255,255,255,0.18);
      --border: rgba(255,255,255,0.16);
      --shadow: 0 20px 60px rgba(0,0,0,0.35);
      --radius-xl: 28px;
      --radius-lg: 20px;
      --radius-md: 16px;
      --font-en: Arial, Helvetica, sans-serif;
      --font-ar: Tahoma, Arial, sans-serif;
    }

    body {
      min-height: 100vh;
      font-family: var(--font-en);
      color: var(--text);
      background: #03101f;
      overflow-x: hidden;
    }

    .screen {
      min-height: 100vh;
      position: relative;
      display: none;
    }

    .screen.active {
      display: block;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: linear-gradient(to bottom, rgba(2,11,23,0.18), rgba(2,11,23,0.72)), url('assets/bg-horizontal.jpg');
      background-size: cover;
      background-position: center;
      z-index: 0;
    }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(59,130,246,0.08), rgba(0,0,0,0.22) 55%, rgba(0,0,0,0.45));
      z-index: 1;
    }

    .hero {
      position: relative;
      z-index: 2;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 28px 28px 24px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }

    .logo img {
      width: 170px;
      max-width: 36vw;
      object-fit: contain;
    }

    .hero-center {
      align-self: flex-end;
      width: min(560px, 100%);
      text-align: center;
      margin-right: 6%;
      margin-top: auto;
      margin-bottom: 5vh;
    }

    .main-title-image {
      width: min(460px, 90%);
      margin: 0 auto 26px;
      display: block;
    }

    .greeting-text {
      font-size: clamp(24px, 3vw, 34px);
      line-height: 1.3;
      font-weight: 600;
      color: var(--white);
      text-shadow: 0 2px 18px rgba(0,0,0,0.25);
      min-height: 90px;
      margin-bottom: 26px;
      white-space: pre-line;
    }

    .input-wrap {
      width: min(460px, 92vw);
      margin: 0 auto;
      padding: 10px;
      border-radius: 999px;
      background: rgba(255,255,255,0.12);
      border: 1px solid var(--border);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      box-shadow: var(--shadow);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .input-wrap input {
      flex: 1;
      background: transparent;
      border: 0;
      outline: 0;
      color: var(--white);
      font-size: 20px;
      padding: 14px 18px;
    }

    .input-wrap input::placeholder {
      color: rgba(255,255,255,0.55);
    }

    .send-btn,
    .action-btn {
      border: 0;
      cursor: pointer;
      font-weight: 700;
      transition: 0.2s ease;
    }

    .send-btn {
      min-width: 120px;
      padding: 16px 26px;
      border-radius: 999px;
      background: var(--white);
      color: #1a2740;
      font-size: 20px;
    }

    .send-btn:hover,
    .action-btn:hover,
    .lang-btn:hover {
      transform: translateY(-1px);
      opacity: 0.96;
    }

    .bottom-bar {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 16px;
      margin-top: 24px;
    }

    .lang-switch {
      display: inline-flex;
      background: rgba(0,0,0,0.38);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 999px;
      overflow: hidden;
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .lang-btn {
      border: 0;
      background: transparent;
      color: rgba(255,255,255,0.85);
      padding: 12px 18px;
      font-weight: 700;
      cursor: pointer;
      min-width: 74px;
    }

    .lang-btn.active {
      background: rgba(255,255,255,0.12);
      color: var(--white);
    }

    .preview-screen {
      background: linear-gradient(180deg, #010a14 0%, #041120 100%);
      padding: 22px 16px 28px;
      display: none;
      min-height: 100vh;
    }

    .preview-screen.active {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
    }

    .card-shell {
      width: min(420px, 100%);
      padding: 18px;
      border-radius: 28px;
      background: rgba(6,18,34,0.95);
      box-shadow: var(--shadow);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .card-export {
      width: 100%;
      aspect-ratio: 9 / 16;
      position: relative;
      overflow: hidden;
      border-radius: 22px;
      background: #061423;
      isolation: isolate;
    }

    .card-export::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: linear-gradient(to bottom, rgba(1,10,20,0.18), rgba(1,10,20,0.18)), url('assets/bg-vertical.jpg');
      background-size: cover;
      background-position: center;
      z-index: -2;
    }

    .card-export::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(1,11,24,0.35), rgba(1,11,24,0.08) 24%, rgba(1,11,24,0.08) 64%, rgba(1,11,24,0.18));
      z-index: -1;
    }

    .card-inner {
      position: absolute;
      inset: 0;
      padding: 26px 22px 32px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .card-logo {
      align-self: flex-start;
      width: 110px;
      margin-bottom: 26px;
    }

    .card-title {
      width: min(300px, 88%);
      margin-bottom: 28px;
    }

    .card-greeting {
      font-size: 24px;
      line-height: 1.35;
      font-weight: 600;
      white-space: pre-line;
      margin-bottom: 18px;
    }

    .card-name {
      font-size: 34px;
      font-weight: 800;
      margin-bottom: auto;
      word-break: break-word;
      max-width: 90%;
      text-shadow: 0 2px 20px rgba(0,0,0,0.28);
    }

    .actions {
      width: min(420px, 100%);
      margin-top: 18px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    .action-btn {
      padding: 18px 16px;
      border-radius: 999px;
      font-size: 19px;
      background: rgba(255,255,255,0.08);
      color: var(--white);
      border: 1px solid rgba(255,255,255,0.12);
    }

    .action-btn.primary {
      background: linear-gradient(180deg, #3c82ff 0%, #256af0 100%);
      border: 0;
    }

    .rtl {
      direction: rtl;
      font-family: var(--font-ar);
    }

    .ltr {
      direction: ltr;
      font-family: var(--font-en);
    }

    @media (max-width: 900px) {
      .hero {
        padding: 18px 16px 18px;
      }

      .logo img {
        width: 130px;
        max-width: 42vw;
      }

      .hero-center {
        align-self: center;
        width: 100%;
        margin-right: 0;
        margin-bottom: 10vh;
      }

      .main-title-image {
        width: min(320px, 85vw);
        margin-bottom: 16px;
      }

      .greeting-text {
        font-size: clamp(18px, 5vw, 26px);
        min-height: 72px;
        margin-bottom: 18px;
      }

      .input-wrap {
        width: min(95vw, 430px);
      }

      .input-wrap input {
        font-size: 18px;
        padding: 12px 14px;
      }

      .send-btn {
        min-width: 96px;
        padding: 14px 18px;
        font-size: 18px;
      }

      .bottom-bar {
        flex-direction: row;
        align-items: center;
      }

      .lang-btn {
        min-width: 64px;
        padding: 10px 14px;
        font-size: 14px;
      }

      .card-greeting {
        font-size: 18px;
      }

      .card-name {
        font-size: 24px;
      }

      .actions {
        grid-template-columns: 1fr 1fr;
      }

      .action-btn {
        font-size: 16px;
        padding: 16px 12px;
      }
    }

    @media (max-width: 520px) {
      .topbar {
        flex-direction: column;
        align-items: flex-start;
      }

      .bottom-bar {
        justify-content: flex-start;
      }

      .actions {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <!-- LANDING SCREEN -->
  <section id="landingScreen" class="screen active">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>

    <div class="hero">
      <div class="topbar">
        <div class="logo">
          <img src="assets/sadara-logo-white.png" alt="Sadara Logo" />
        </div>
      </div>

      <div class="hero-center" id="heroCenter">
        <img id="mainTitleImage" class="main-title-image" src="assets/title-en.png" alt="Ramadan Mubarak" />
        <div id="greetingText" class="greeting-text ltr">Wishing you\na blessed Ramadan</div>

        <div class="input-wrap" id="inputWrap">
          <input id="nameInput" type="text" maxlength="40" placeholder="Type your name here..." />
          <button id="sendBtn" class="send-btn" type="button">Send</button>
        </div>
      </div>

      <div class="bottom-bar">
        <div class="lang-switch">
          <button class="lang-btn" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="ar">عربي</button>
          <button class="lang-btn active" data-lang="both">AR&EN</button>
        </div>
      </div>
    </div>
  </section>

  <!-- PREVIEW / DOWNLOAD SCREEN -->
  <section id="previewScreen" class="preview-screen">
    <div class="card-shell">
      <div id="exportCard" class="card-export">
        <div class="card-inner">
          <img class="card-logo" src="assets/sadara-logo-white.png" alt="Sadara Logo" />
          <img id="cardTitleImage" class="card-title" src="assets/title-en.png" alt="Ramadan Mubarak" />
          <div id="cardGreeting" class="card-greeting ltr">Wishing you\na blessed Ramadan</div>
          <div id="cardName" class="card-name">Test</div>
        </div>
      </div>
    </div>

    <div class="actions">
      <button id="downloadBtn" class="action-btn primary" type="button">⬇ Download Card</button>
      <button id="newCardBtn" class="action-btn" type="button">↻ New Card</button>
    </div>
  </section>

  <script>
    const landingScreen = document.getElementById('landingScreen');
    const previewScreen = document.getElementById('previewScreen');
    const greetingText = document.getElementById('greetingText');
    const cardGreeting = document.getElementById('cardGreeting');
    const nameInput = document.getElementById('nameInput');
    const sendBtn = document.getElementById('sendBtn');
    const cardName = document.getElementById('cardName');
    const downloadBtn = document.getElementById('downloadBtn');
    const newCardBtn = document.getElementById('newCardBtn');
    const mainTitleImage = document.getElementById('mainTitleImage');
    const cardTitleImage = document.getElementById('cardTitleImage');
    const heroCenter = document.getElementById('heroCenter');
    const inputWrap = document.getElementById('inputWrap');
    const exportCard = document.getElementById('exportCard');

    let selectedLanguage = 'both';

    const content = {
      en: {
        greeting: 'Wishing you\na blessed Ramadan',
        placeholder: 'Type your name here...',
        send: 'Send',
        download: '⬇ Download Card',
        newCard: '↻ New Card',
        titleImage: 'assets/title-en.png',
        dir: 'ltr'
      },
      ar: {
        greeting: 'تقبل الله منا ومنكم الصيام\nوالقيام وصالح الأعمال',
        placeholder: '...اكتب اسمك هنا',
        send: 'إرسال',
        download: '⬇ تحميل البطاقة',
        newCard: '↻ بطاقة جديدة',
        titleImage: 'assets/title-ar.png',
        dir: 'rtl'
      },
      both: {
        greeting: 'تقبل الله منا ومنكم الصيام\nوالقيام وصالح الأعمال\nWishing you\na blessed Ramadan',
        placeholder: '...اكتب اسمك هنا',
        send: 'Send',
        download: '⬇ Download Card',
        newCard: '↻ New Card',
        titleImage: 'assets/title-both.png',
        dir: 'ltr'
      }
    };

    function setDirection(element, dir) {
      element.classList.remove('rtl', 'ltr');
      element.classList.add(dir === 'rtl' ? 'rtl' : 'ltr');
    }

    function applyLanguage(lang) {
      selectedLanguage = lang;
      const data = content[lang];

      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
      });

      greetingText.textContent = data.greeting;
      cardGreeting.textContent = data.greeting;
      nameInput.placeholder = data.placeholder;
      sendBtn.textContent = data.send;
      downloadBtn.textContent = data.download;
      newCardBtn.textContent = data.newCard;
      mainTitleImage.src = data.titleImage;
      cardTitleImage.src = data.titleImage;

      if (lang === 'ar') {
        heroCenter.style.textAlign = 'right';
        inputWrap.style.direction = 'rtl';
      } else {
        heroCenter.style.textAlign = 'center';
        inputWrap.style.direction = 'ltr';
      }

      setDirection(greetingText, data.dir);
      setDirection(cardGreeting, data.dir);
      setDirection(nameInput, lang === 'ar' ? 'rtl' : 'ltr');
      setDirection(cardName, lang === 'ar' ? 'rtl' : 'ltr');
    }

    document.querySelectorAll('.lang-btn').forEach(btn => {
      btn.addEventListener('click', () => applyLanguage(btn.dataset.lang));
    });

    sendBtn.addEventListener('click', () => {
      const enteredName = nameInput.value.trim();
      if (!enteredName) {
        alert(selectedLanguage === 'ar' ? 'يرجى كتابة الاسم أولاً' : 'Please enter your name first');
        return;
      }

      cardName.textContent = enteredName;
      landingScreen.classList.remove('active');
      previewScreen.classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    newCardBtn.addEventListener('click', () => {
      previewScreen.classList.remove('active');
      landingScreen.classList.add('active');
      nameInput.value = '';
      nameInput.focus();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    downloadBtn.addEventListener('click', async () => {
      try {
        const canvas = await html2canvas(exportCard, {
          scale: 2,
          useCORS: true,
          backgroundColor: null
        });

        const link = document.createElement('a');
        const safeName = (cardName.textContent || 'card').replace(/[^a-zA-Z0-9\u0600-\u06FF-_ ]/g, '').trim() || 'card';
        link.download = `${safeName}-sadara-ramadan-card.png`;
        link.href = canvas.toDataURL('image/png');
        link.click();
      } catch (error) {
        console.error('Download failed:', error);
        alert('Failed to download card.');
      }
    });

    nameInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') sendBtn.click();
    });

    applyLanguage('both');
  </script>
</body>
</html>
